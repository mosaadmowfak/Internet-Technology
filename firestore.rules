rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Learning Hub: students must read published videos/articles without signing in.
    match /learningHubSubmissions/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Comments (optional: tighten later)
    match /learningComments/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    match /communityPosts/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /communityComments/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    match /eventSubmissions/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /eventRegistrations/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    match /ideas/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
